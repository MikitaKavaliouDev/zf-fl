  final String duration;
  final ValueChanged<String> onChanged;

  const _DurationPicker({
    required this.duration,
    required this.onChanged,
  });

  @override
  Widget build(BuildContext context) {
    const options = [
      ('30_days', '30 Days'),
      ('90_days', '90 Days'),
      ('forever', 'Forever'),
