              if (context.mounted) {
                final cubit = context.read<WorkoutSessionCubit>();
                cubit.logSet(
                  logId: log.id,
                  exerciseId: exerciseId,
                  reps: log.reps ?? 0,
                  weight: log.weight,
                  isCompleted: log.isCompleted,
                  rpe: log.rpe,
                  tempo: tempo.isEmpty ? null : tempo,
