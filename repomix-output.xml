  Widget _buildRetentionPicker({
    bool isLast = false,
  }) {
    const options = [90, 180, 365, 730, null];
    String label(int? days) {
      switch (days) {
        case 90:
          return '3 Months';
        case 180:
          return '6 Months';
        case 365:
          return '1 Year';
        case 730:
          return '2 Years';
        case null:
          return 'Indefinitely';
        default:
          return '$days days';
      }
    }

    return Column(
      children: [
        Padding(
          padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
          child: Row(
            children: [
              Container(
