                    const SizedBox(height: 12),
                    FilledButton.icon(
                      onPressed: () => context
                          .read<TrainerClientAnalyticsCubit>()
                          .loadAnalytics(clientId),
                      icon: const Icon(Icons.refresh_rounded),
                      label: const Text('Retry'),
                    ),
                  ],
                ),
              ),
            TrainerClientAnalyticsLoaded(:final analytics) =>
