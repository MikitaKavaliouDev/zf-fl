///   context: context,
///   builder: (_) => FinishWorkoutDialog(
///     onCompleteUnfinished: () => cubit.finishWithOption(.completeUnfinished),
///     onDiscardUnfinished: () => cubit.finishWithOption(.discardUnfinished),
///     onCancel: () => Navigator.of(context).pop(),
